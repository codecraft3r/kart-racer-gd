; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="kart_racer"
run/main_scene="res://default_3d.tscn"
config/features=PackedStringArray("4.7", "C#", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/image="res://assets/loading/pain_loading.png"
config/icon="res://icon.svg"
boot_splash/minimum_display_time=1000

[autoload]

AudioManager="*res://audio/AudioManager.cs"
MultiplayerManager="*res://MultiplayerManager.cs"

[dotnet]

project/assembly_name="kart_racer"

