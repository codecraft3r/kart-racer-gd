root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_style = space
indent_size = 4

[{*.gd,*.tscn,*.tres,*.godot,*.cfg,*.import,*.csproj,*.sln}]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
